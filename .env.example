APP_NAME=Home Collection Mobile API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=2010
APP_DEBUG=false

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=lead_management
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE=1800
CATALOG_MYSQL_HOST=127.0.0.1
CATALOG_MYSQL_PORT=3306
CATALOG_MYSQL_USER=your_mysql_user
CATALOG_MYSQL_PASSWORD=your_mysql_password
CATALOG_MYSQL_DB=bhasin_7001_new

JWT_SECRET_KEY=change_this_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

CORS_ORIGINS=["*"]

SSL_CERT_FILE=./certs/server.crt
SSL_KEY_FILE=./certs/server.key
PATIENT_DOCUMENTS_UPLOAD_BASE=./app/static/uploads/patient_documents

